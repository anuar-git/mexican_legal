# =============================================================================
# Legal Intelligence Engine — Dashboard Image
#
# Intentionally lightweight: only streamlit + pandas are installed.
# PyTorch, sentence-transformers, Pinecone, and LangChain are NOT needed here.
#
# The dashboard reads the SQLite request log at /app/data/requests.db, which
# is bind-mounted read-only from the host (see docker-compose.yml).
# =============================================================================

FROM python:3.12-slim

# Non-root user — matches the API image convention.
RUN groupadd --gid 1001 appgroup \
    && useradd --uid 1001 --gid appgroup \
               --no-create-home --shell /bin/false appuser

# Install only what the dashboard needs.
# pip upgrade first to avoid hash-mismatch warnings on slim base.
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir \
        "streamlit>=1.35" \
        "pandas>=2.0" \
        "plotly>=5.0"

# Copy monitoring source only — no ingestion, retrieval, or API code needed.
COPY src/monitoring/ /app/src/monitoring/

WORKDIR /app

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Runtime env defaults; overridden by docker-compose environment: block.
ENV API_URL=http://api:8000

USER appuser

EXPOSE 8501

# Streamlit's built-in health endpoint — no extra deps required.
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD python -c \
        "import urllib.request; urllib.request.urlopen('http://localhost:8501/_stcore/health')" \
        2>/dev/null || exit 1

CMD ["streamlit", "run", "src/monitoring/dashboard.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
