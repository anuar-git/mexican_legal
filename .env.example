# =============================================================================
# Legal Intelligence Engine — Environment Variables
#
# Copy this file to .env and fill in the real values.
# .env is gitignored and must NEVER be committed.
#
# For Railway deployment: set these as project variables in the Railway UI.
# For Docker Compose: docker compose reads .env automatically.
# =============================================================================

# ── External services (required) ─────────────────────────────────────────────

# Pinecone — https://app.pinecone.io → API Keys
PINECONE_API_KEY=your_pinecone_api_key_here

# Pinecone index — must already exist (created by scripts/ingest.py)
PINECONE_INDEX_NAME=legal-intelligence

# Anthropic — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Admin ─────────────────────────────────────────────────────────────────────

# Required by POST /v1/evaluate.  The endpoint returns 503 if unset.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=your_admin_api_key_here

# ── Pinecone index location (optional) ───────────────────────────────────────

# Cloud provider and region where the Pinecone serverless index lives.
# These must match the values used when the index was created.
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── API behaviour (optional) ──────────────────────────────────────────────────

# Runtime environment label.  Controls nothing directly; logged at startup
# and available for future feature-flag checks.
ENVIRONMENT=production

# Root logger level.  One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Set to true only for local debugging — exposes raw exception messages in
# HTTP 500 responses.  NEVER set to true in production.
DEBUG=false

# Comma-separated list of allowed CORS origins.
# Use "*" to allow all origins (fine for a public read-only API).
# Example: https://myapp.com,https://staging.myapp.com
ALLOWED_ORIGINS=*

# Rate limiting — requests allowed per IP per window.
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_S=60
