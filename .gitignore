# =============================================================================
# Legal Intelligence Engine — .gitignore
# =============================================================================

# ── Secrets — never commit ────────────────────────────────────────────────────
.env
*.env.*
!.env.example

# ── Python runtime artefacts ─────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Tool caches ───────────────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ── Generated data ────────────────────────────────────────────────────────────
# Raw source document — large binary, not useful in git history
data/raw/
# Embedding checkpoints — regenerated by ingest.py
data/processed/
# SQLite request log — runtime data, not source code
data/requests.db
# Evaluation output files
results/

# ── IDE and OS noise ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.DS_Store
Thumbs.db
